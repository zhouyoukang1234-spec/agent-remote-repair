# ═══════════════════════════════════════════════════════════
# 道 · 远程中枢 — 环境配置
#
# 道可道 非常少。0 配置即可启动：
#   node dao.js
# 此文件全部为"首选值覆盖"，留空即从随机熵 / 端口探测 / 隧道涌现。
# ═══════════════════════════════════════════════════════════

# ── 核心 ──
# PORT=3002            # 中枢主端口。被占用时自动 +1 重试。也可 --port 3002
# DAO_TOKEN=<自动>      # master token（操控端 Bearer）。留空=随机生成并持久化到 ~/.dao-remote/conn.json

# ── 公网入口 ──
# NO_TUNNEL=1          # 禁用 cloudflared/ngrok/SSH 公网隧道（= --no-tunnel）
# DAO_LAN_ONLY=1       # 两仪不出门：仅局域网（= --lan-only）
# DAO_RELAY_URL=https://<your>.workers.dev   # 设了则走 Worker+DO 稳定隧道（信封模式），否则默认 cloudflared 透明隧道

# ── 被控端别名（短名 → 真 hostname）──
# DAO_ALIASES={"141":"DESKTOP-MASTER","179":"ZHOUMAC"}

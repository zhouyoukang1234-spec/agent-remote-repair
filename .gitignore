node_modules/
remote-agent/node_modules/
__pycache__/
*.pyc

# Build artifacts
web/.next/
web/out/

# Environment & secrets (never commit real tokens)
.env
*.env.local

# Deployment (contains auth tokens & local paths)
frpc.toml
start_service.bat
*.local.bat

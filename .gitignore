# PS Agent state (runtime)
ps-agent/dao_state.json

# System
.DS_Store
Thumbs.db
*.log
*.err
_dao_*.pid
_dao_*.txt

# IDE
.vscode/
.idea/

# Windsurf
web/windsurf_deployment.yaml

# Dao Kernel identity (per-device keypair, never share)
.dao-remote/

# Temp / binaries
bin/
cloudflared.exe
*.exe
.vscode-test/
*.vsix
